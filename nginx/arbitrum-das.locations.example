# Location blocks only — merge into an existing `server { listen 443 ssl; ... }`
# for DAS_DOMAIN if you already terminate TLS there (README step 8.4, option A).
#
# After copying, replace DAS_RPC_SECRET_PATH (or use sed from env/das.network.env).

    # Private RPC (batch poster). Share https://<domain>/rpc/<secret> out-of-band only.
    location = /rpc/DAS_RPC_SECRET_PATH {
        proxy_pass http://127.0.0.1:9876/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /rpc/DAS_RPC_SECRET_PATH/ {
        proxy_pass http://127.0.0.1:9876/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Public REST (Nitro rest-aggregator). Health: /rest/health
    location /rest/ {
        proxy_pass http://127.0.0.1:9877/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
