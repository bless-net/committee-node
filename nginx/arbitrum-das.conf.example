# Example nginx site for committee-node DAS exposure (README step 8).
#
# Copy to the host, substitute placeholders from env/das.network.env, then:
#   sudo nginx -t && sudo systemctl reload nginx
#
# Placeholders (replaced by step 8.4 commands):
#   DAS_DOMAIN            — public DNS name (e.g. das-member.example.com)
#   DAS_RPC_SECRET_PATH   — openssl rand -hex 16
#   DAS_TLS_CERT          — full chain PEM (e.g. /etc/ssl/certs/das-fullchain.pem)
#   DAS_TLS_KEY           — private key PEM (e.g. /etc/ssl/private/das-privkey.pem)

server {
    listen 80;
    server_name DAS_DOMAIN;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name DAS_DOMAIN;

    ssl_certificate     DAS_TLS_CERT;
    ssl_certificate_key DAS_TLS_KEY;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Private RPC (batch poster writer path). Share this URL out-of-band only.
    location = /rpc/DAS_RPC_SECRET_PATH {
        proxy_pass http://127.0.0.1:9876/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /rpc/DAS_RPC_SECRET_PATH/ {
        proxy_pass http://127.0.0.1:9876/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Public REST (Nitro rest-aggregator readers). Health: /rest/health
    location /rest/ {
        proxy_pass http://127.0.0.1:9877/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
