# Image (digest-pinned)
# offchainlabs/nitro-node:v3.9.8-4624977 (linux/amd64)
DAS_IMAGE=offchainlabs/nitro-node@sha256:597b913351e0efcd3452c9921d6f9b64e4e89de77dec2cabcc05f784d0f9b969

# Core chain inputs
CHAIN_NAME=Blessnet
PARENT_CHAIN_RPC=https://REPLACE_ME
SEQUENCER_INBOX_ADDRESS=0xREPLACE_ME

# Other committee members' public REST bases (comma-separated, no spaces).
# Do not include your own URL — siblings only. Each must end with /rest (nginx path).
# Get the list from Blessnet ops (README step 6 / step 9).
# Example: https://das-alpha.test.bless.net/rest,https://das-beta.test.bless.net/rest
DAS_REST_AGGREGATOR_URLS=REPLACE_ME

# Bind addresses (see README step 8 for committee networking)
# Keep 127.0.0.1 for both when exposing DAS via nginx on 443.
DAS_RPC_BIND=127.0.0.1
DAS_REST_BIND=127.0.0.1
DAS_CPU_LIMIT=1.0
DAS_MEM_LIMIT=2g
