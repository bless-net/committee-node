# Copy to env/das.network.env and fill in (gitignored).
# Used when exposing DAS REST via Caddy (README step 8).

# Droplet public IP (curl -4 -s ifconfig.me)
NODE_PUBLIC_IP=REPLACE_ME

# Sequencer / batch-poster source IP for DAS RPC allowlisting (CIDR ok)
SEQUENCER_IP=REPLACE_ME

# Secret path prefix for public REST — generate once, do not rotate casually
# (Blessnet registers this URL in the DAC keyset).
# Example: openssl rand -hex 16
DAS_REST_PATH_PREFIX=REPLACE_ME
