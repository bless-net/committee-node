# Copy to env/das.network.env and fill in (gitignored).
# Used in README step 8 (nginx HTTPS exposure).

# mainnet | testnet — sets default AWS_TLS_* secret names (see docs/tls-aws-secrets-manager.md)
COMMITTEE_PROFILE=mainnet

# Public DNS name for this committee node (must match wildcard cert for profile)
# Create an A record: this hostname → this droplet's public IP (curl -4 -s ifconfig.me)
# mainnet: *.bless.net   e.g. das-member.bless.net  (A record "das-member" → 203.0.113.10)
# testnet: *.test.bless.net   e.g. das-member.test.bless.net
DAS_DOMAIN=REPLACE_ME

# TLS certificate paths on the host (populated by scripts/fetch-tls-from-aws.sh)
DAS_TLS_CERT=/etc/ssl/certs/das-fullchain.pem
DAS_TLS_KEY=/etc/ssl/private/das-privkey.pem

# AWS Secrets Manager (defaults shown for mainnet; overridden when COMMITTEE_PROFILE=testnet)
AWS_REGION=us-east-1
AWS_TLS_CRT_SECRET=blessnet/mainnet/tls/wildcard-crt
AWS_TLS_KEY_SECRET=blessnet/mainnet/tls/wildcard-key
# Optional: AWS_PROFILE=blessnet-committee

# Secret suffix for private RPC path — generate once: make gen-das-rpc-secret-path
# Registered RPC URL: https://${DAS_DOMAIN}/rpc/${DAS_RPC_SECRET_PATH}
DAS_RPC_SECRET_PATH=REPLACE_ME
